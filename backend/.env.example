# Runtime connection used by the FastAPI app — restricted role (INSERT/SELECT only on ledger tables)
DATABASE_URL=postgresql+asyncpg://eye_app:eye_app_devpassword@localhost:5432/the_eye

# Elevated connection used only by Alembic migrations (creates roles/schemas/grants/triggers)
ADMIN_DATABASE_URL=postgresql+asyncpg://eye_admin:devpassword@localhost:5432/the_eye

ENV=development

# Optional: AI investigate feature (Phase 2E). Leave empty to disable --
# the feature returns a clear "not configured" message rather than failing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Paddle Billing -- required for self-serve signup and subscription gating.
# PADDLE_WEBHOOK_SECRET: Paddle dashboard → Notifications → your webhook → secret key
# PADDLE_PRICE_ID: the subscription price ID (pri_xxx) shown in Paddle Catalog
# PADDLE_ENVIRONMENT: "sandbox" for testing, "production" for live payments
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
PADDLE_ENVIRONMENT=sandbox
